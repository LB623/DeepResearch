# Research and reasoning models
RESEARCH_LLM_MODEL=your-research-model
RESEARCH_LLM_API_KEY=your-api-key
RESEARCH_LLM_BASE_URL=https://your-llm-endpoint/v1

REASONING_LLM_MODEL=your-reasoning-model
REASONING_LLM_API_KEY=your-api-key
REASONING_LLM_BASE_URL=https://your-llm-endpoint/v1

# Legacy single-model fallback (optional)
# APP_TOKEN=your-api-key
# LLM_BASE_URL=https://your-llm-endpoint/v1

# Embedding API Configuration
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://your-embedding-endpoint/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# MCP Tool Configuration（Web搜索，使用达摩院 dashscope SDK）
# 可通过 DASHSCOPE_HTTP_BASE_URL 自定义API地址（不配则默认 dashscope.aliyuncs.com）
# 可通过 DASHSCOPE_API_KEY 自定义API Key（不配则 fallback 到 APP_TOKEN）
MCP_API_KEY=your-dashscope-api-key
MCP_APP_ID=your-web-search-application-id
# DASHSCOPE_HTTP_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# DASHSCOPE_API_KEY=sk-xxxxxxxx

# LangSmith Configuration (Optional)
# LANGSMITH_API_KEY=你的LangSmith API

# Available Models Configuration (JSON format)
# Format: [{"model_id":"","display_name":"","icon":"Zap or Cpu","icon_color":"tailwind_color_class"}]
AVAILABLE_MODELS=[{"model_id":"qwen3.6-flash","display_name":"Qwen-Flash","icon":"Zap","icon_color":"yellow-400"},{"model_id":"qwen3.6-plus","display_name":"Qwen-Plus","icon":"Zap","icon_color":"orange-400"},{"model_id":"qwen3.7-max-2026-05-17","display_name":"Qwen-Max","icon":"Cpu","icon_color":"purple-400"}]

# Web Search Rate Limiting Configuration
WEB_SEARCH_MAX_QPS=12

# Redis search cache and LangGraph checkpoint
REDIS_URL=redis://localhost:6379/0
CHECKPOINT_BACKEND=redis
CHECKPOINT_REDIS_URL=redis://localhost:6379/0

# Milvus Configuration
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=research_facts

# KB Lifecycle Mode — controls freshness filtering for Milvus facts
# off       : no filtering, no decay, no age tags (current behavior)
# inform    : age tags + wording change ("please verify"), no filtering
# freshness : Plan LLM freshness level → unified threshold (7/30/180d) + confidence decay (default)
# lifecycle : fact category → per-category TTL (market 7d / product 30d / strategy 90d / tech 180d / historical never)
KB_LIFECYCLE_MODE=freshness

# Research Configuration
NUMBER_OF_INITIAL_QUERIES=2

MAX_RESEARCH_LOOPS=2
